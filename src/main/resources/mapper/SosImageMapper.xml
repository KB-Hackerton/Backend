<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kb_hack.backend.domain.sos.mapper.SosImageMapper">

    <insert id="insert" parameterType="kb_hack.backend.domain.sos.entity.SosImage" useGeneratedKeys="true" keyProperty="sosImageId" keyColumn="sos_image_id">
        INSERT INTO sos_image
            (sos_id, storage_key, is_deleted)
        VALUES
            (#{sosId}, #{storageKey}, #{isDeleted})
    </insert>

</mapper>
