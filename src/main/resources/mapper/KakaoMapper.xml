<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kb_hack.backend.domain.kakao.mapper.KakaoMapper">

    <resultMap id="authMap" type="kb_hack.backend.global.security.entity.MemberAuthVO">
        <result property="auth" column="auth"/>
    </resultMap>

    <resultMap id="BusinessMap" type="kb_hack.backend.domain.business.dto.BusinessDTO">
        <id property="businessId" column="business_id"/>
        <result property="businessClassId" column="business_class_id"/>
        <result property="businessNm" column="business_nm"/>
        <result property="businessAddr" column="business_addr"/>
        <result property="businessAddrDetail" column="business_addr_detail"/>
        <result property="businessCode" column="business_code"/>
        <result property="businessOpenDate" column="business_open_date"/>
    </resultMap>


    <resultMap id="MemberMap" type="kb_hack.backend.global.security.entity.MemberVO">
        <id     property="memberId"       column="member_id"/>
        <result property="profileImageId" column="profile_image_id"/>
        <result property="memberEmail"    column="member_email"/>
        <result property="password"       column="password"/>
        <result property="memberName"     column="member_name"/>
        <result property="createdAt"      column="created_at"/>
        <result property="helpCount"      column="help_count"/>
        <result property="badge"          column="badge"/>
        <association property="businessDTO" resultMap="BusinessMap"/>
        <collection property="authMap" resultMap="authMap"/>
    </resultMap>



    <select id="existsByKakaoId" parameterType="long" resultType="int">
        SELECT COUNT(*)
        FROM member
        WHERE kakao_id = #{kakaoId};
    </select>

    <select id="findByKakaoId" resultMap="MemberMap">
        SELECT
            m.member_id,
            m.profile_image_id,
            m.member_email,
            m.password,
            m.member_name,
            m.created_at,
            m.help_count,
            m.badge,
            a.auth,
            b.business_id,
            b.business_class_id,
            b.business_nm,
            b.business_addr,
            b.business_addr_detail,
            b.business_code,
            b.business_open_date
        FROM member m
                 LEFT JOIN auth a ON a.member_id = m.member_id
                 LEFT JOIN business b ON b.member_id = m.member_id
        WHERE m.kakao_id = #{id}
    </select>

</mapper>