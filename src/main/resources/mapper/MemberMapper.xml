<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kb_hack.backend.domain.member.mapper.MemberMapper">

    <insert id="insertMember" parameterType="kb_hack.backend.domain.member.dto.MemberDTO"
            useGeneratedKeys="true" keyProperty="memberId">
        INSERT INTO member(member_email,password,member_name,status,help_count,badge)
        VALUES(#{memberEmail},#{password},#{memberName},#{status},#{helpCount},#{badge})
    </insert>
    <insert id="insertAuth" parameterType="kb_hack.backend.domain.member.dto.AuthDTO">
        INSERT INTO auth (member_id,auth)
        VALUES (#{memberId},#{auth})
    </insert>
    <delete id="deleteUser" parameterType="long">
        delete from member
        where member_id = #{memberId}
    </delete>

    <update id="updatePasswordByMemberEmail">
        UPDATE member
        SET password = #{newPassword}
        WHERE member_email =#{memberEmail}

    </update>
    <update id="updateMembernameByMemberId">
        UPDATE member
        SET member_name = #{memberName}
        WHERE member_id = #{memberId}
    </update>


</mapper>
