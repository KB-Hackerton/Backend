<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kb_hack.backend.global.security.mapper.SecurityMemberMapper">

    <resultMap id="authMap" type="kb_hack.backend.global.security.entity.MemberAuthVO">
        <result property="auth" column="auth"/>
    </resultMap>

    <resultMap id="MemberMap" type="kb_hack.backend.global.security.entity.MemberVO">
        <id     property="memberId"       column="member_id"/>
        <result property="profileImageId" column="profile_image_id"/>
        <result property="memberEmail"    column="member_email"/>
        <result property="password"       column="password"/>
        <result property="memberName"     column="member_name"/>
        <result property="createdAt"      column="created_at"/>
        <result property="helpCount"      column="help_count"/>
        <result property="badge"          column="badge"/>
        <collection property="authMap" resultMap="authMap"/>
    </resultMap>




    <select id="getMemberByMemberEmail" parameterType="string" resultMap="MemberMap">
        SELECT
            m.member_id,
            m.profile_image_id,
            m.password,
            m.member_email,
            m.password,
            m.member_name,
            m.created_at,
            m.help_count,
            m.badge,
            a.auth

        FROM member m
                 LEFT JOIN auth a
                           ON a.member_id = m.member_id
        WHERE m.member_email = #{memberEmail}

    </select>
</mapper>
